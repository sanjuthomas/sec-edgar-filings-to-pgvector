# Shared Docker network (created by sec-edgar-filings-crawler compose)
SEC_EDGAR_DOCKER_NETWORK=sec-edgar_default

# Local data root — all bind-mount paths below live under this directory
LOCAL_DATA_ROOT=/path/to/your/sec-edgar-data

# PostgreSQL + ParadeDB (pgvector + pg_search BM25)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/edgar
PGVECTOR_HOST_PATH=${LOCAL_DATA_ROOT}/pgvector-data
POSTGRES_HOST_PATH=${LOCAL_DATA_ROOT}/postgres-data

# MongoDB — runs in sec-edgar-filings-crawler compose
MONGO_HOST_PATH=${LOCAL_DATA_ROOT}/mongo-data
MONGO_URI=mongodb://mongo:27017
MONGO_DB=sec_edgar_filings
MONGO_FILING_METADATA_COLLECTION=filing_metadata
MONGO_TIMEOUT_MS=2000

# HuggingFace model cache — bind-mounted into pgvector-browser and edgar-pgvector-etl
HF_CACHE_HOST_PATH=${LOCAL_DATA_ROOT}/hf-cache

# SEC EDGAR filing .htm files (shared with sec-edgar-filings-crawler)
SEC_EDGAR_DOCUMENT_ROOT=${LOCAL_DATA_ROOT}/edgar-filings
EDGAR_HOST_PATH=${SEC_EDGAR_DOCUMENT_ROOT}
EDGAR_DATA_DIR=${SEC_EDGAR_DOCUMENT_ROOT}
ALLOWED_FORMS=10-K,10-Q,10-K/A,10-Q/A,8-K,8-K/A

# Kafka — runs in sec-edgar-filings-crawler compose (service name: kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=filings
KAFKA_GROUP_ID=edgar-pgvector-etl
KAFKA_AUTO_OFFSET_RESET=earliest

# Embedding model (1024 dimensions for BGE-M3)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BACKEND=embedded
# Shared JSON file — ETL (:8001) and search UI (:8000) read the same backend choice
EMBEDDING_CONFIG_PATH=/app/config/embedding-backend.json
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_MAX_SEQ_LENGTH=512
EMBEDDING_BATCH_SIZE=16

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Logging
LOG_LEVEL=INFO
